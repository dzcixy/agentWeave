      <data key="d27">file_write</data>
      <data key="d28">echo "import numpy as np" &gt; test_separability.py
echo "from astropy.modeling import models as m" &gt;&gt; test_separability.py
echo "from astropy.modeling.separable import separability_matrix" &gt;&gt; test_separability.py
echo "" &gt;&gt; test_separability.py
echo "def test_separability_nested_models():" &gt;&gt; test_separability.py
echo "    cm = m.Linear1D(10) &amp; m.Linear1D(5)" &gt;&gt; test_separability.py
echo "    assert np.array_equal(separability_matrix(cm), np.array([[True, False], [False, True]]))" &gt;&gt; test_separability.py
echo "" &gt;&gt; test_separability.py
echo "    cm_nested = m.Pix2Sky_TAN() &amp; cm" &gt;&gt; test_separability.py
echo "    assert np.array_equal(separability_matrix(cm_nested), np.array([[True, True, False, False], [True, True, False, False], [False, False, True, True], [False, False, True, True]]))" &gt;&gt; test_separability.py
echo "" &gt;&gt; test_separability.py
echo "if __name__ == '__main__':" &gt;&gt; test_separability.py
echo "    test_separability_nested_models()" &gt;&gt; test_separability.py</data>
