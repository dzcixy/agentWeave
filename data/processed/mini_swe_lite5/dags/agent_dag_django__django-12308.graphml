      <data key="d28">pip install django
cd /testbed
django-admin startproject myproject .
cd myproject
django-admin startapp myapp
echo "from django.contrib import admin\nfrom django.db import models" &gt; myapp/models.py
echo "class MyModel(models.Model):\n    data = models.JSONField()" &gt;&gt; myapp/models.py
echo "@admin.register(MyModel)\nclass MyModelAdmin(admin.ModelAdmin):\n    readonly_fields = ('data',)" &gt;&gt; myapp/admin.py
echo "INSTALLED_APPS += ['myapp']" &gt;&gt; settings.py
python manage.py makemigrations
python manage.py migrate
python manage.py runserver &amp;
sleep 5
curl http://localhost:8000/admin/myapp/mymodel/
killall python</data>
